@@ -157,8 +157,20 @@ abstract final class Platform {
 
   /// Whether the operating system is a version of
   /// [iOS](https://en.wikipedia.org/wiki/IOS).
+  ///
+  /// On tvOS this also returns `true`, because tvOS is an iOS-family
+  /// operating system. Use [isTvOS] or `operatingSystem == "tvos"` to
+  /// distinguish tvOS from phone/tablet iOS.
+  @pragma("vm:platform-const")
+  static final bool isIOS =
+      (operatingSystem == "ios" || operatingSystem == "tvos");
+
+  /// Whether the operating system is a version of
+  /// [tvOS](https://en.wikipedia.org/wiki/TvOS).
+  ///
+  /// tvOS is an iOS-family OS, so [isIOS] is also `true` on tvOS.
   @pragma("vm:platform-const")
-  static final bool isIOS = (operatingSystem == "ios");
+  static final bool isTvOS = (operatingSystem == "tvos");
 
   /// Whether the operating system is a version of
   /// [Fuchsia](https://en.wikipedia.org/wiki/Google_Fuchsia).
